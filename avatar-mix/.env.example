# Copia a .env y rellena. El MCP de HeyGen usa OAuth (no necesita key),
# pero la API key es el FALLBACK para controlar fondo verde / dimensiones
# en los clips de modo "corner" si el MCP no expone esos parametros.
HEYGEN_API_KEY=

# Endpoint REST v2 (no cambiar salvo que HeyGen lo actualice)
HEYGEN_API_BASE=https://api.heygen.com

# Upload-Post: publicar en redes (subida directa del fichero local via API).
# Consigue tu key en https://app.upload-post.com (Settings → API).
UPLOAD_POST_API_KEY=
UPLOAD_POST_API_BASE=https://api.upload-post.com/api
