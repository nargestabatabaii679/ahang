# Copy to .env.local and fill in your keys.

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Pipeline flags ───────────────────────────────────────────────────────────
# PIPELINE_MOCK=true              # skip real API calls; use placeholders
MUSIC_PROVIDER=riffusion          # riffusion | suno
VIDEO_PROVIDER=heygen             # heygen | synclabs | higgsfield | aurora | omnihuman

# ── HeyGen (Avatar V) ────────────────────────────────────────────────────────
# Get your key at https://app.heygen.com → Settings → API
# Discover avatar/voice IDs with list_avatar_looks / list_voices (HeyGen MCP)
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ── Music: Riffusion (self-hosted) ───────────────────────────────────────────
RIFFUSION_API_BASE=http://localhost:3013

# ── Voice: ElevenLabs ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Video: Sync.so (lipsync alternative) ─────────────────────────────────────
# SYNCLABS_API_KEY=

# ── Video: Higgsfield.ai (lipsync alternative) ───────────────────────────────
# HIGGSFIELD_API_KEY=

# ── Publishing: Upload-Post ───────────────────────────────────────────────────
UPLOAD_POST_API_KEY=
