# ── songai environment ───────────────────────────────────────────────
# Copy this file to `.env.local` and fill in your keys.
# To preview the whole UI + smooth loading without real API calls,
# set PIPELINE_MOCK=true (the pipeline will simulate each stage).

PIPELINE_MOCK=false

# ── ElevenLabs — real voice clone (IVC) + text-to-speech ─────────────
# https://elevenlabs.io  →  Profile → API Keys
ELEVENLABS_API_KEY=
# Optional: model used for the cloned singing/speech voice
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Music — Riffusion (default) or Suno ──────────────────────────────
# MUSIC_PROVIDER selects the backend: "riffusion" (default) or "suno".
MUSIC_PROVIDER=riffusion

# Riffusion: a self-hosted model server (GPU recommended). See
# src/lib/providers/riffusion.ts for the one-time setup commands.
# It returns both audio AND the spectrogram image it diffused, which
# songai uses as the song's cover art.
RIFFUSION_API_BASE=http://localhost:3013

# Suno — alternative instrumental/backing-music provider, used only when
# MUSIC_PROVIDER=suno. Set BASE_URL to your Suno API provider's base.
SUNO_API_KEY=
SUNO_API_BASE=https://api.sunoapi.org

# ── Video — RunComfy CLI (lipsync skill: OmniHuman by default) ───────
# songai's input is a still PHOTO + audio, which the lipsync skill routes
# to ByteDance OmniHuman (avatar-style), not Kling/Sync Labs (those need a
# source VIDEO). Install + auth the CLI once on the machine running this
# app — there is no API key to put here:
#   npm i -g @runcomfy/cli
#   runcomfy login                  # or set RUNCOMFY_TOKEN in this env
# VIDEO_PROVIDER selects the model route: "omnihuman" (default), "kling"
# (only meaningful with a source-video upload instead of a photo), or
# "aurora" (Creatify — same image+audio job, alternative vendor/quality;
# see src/lib/providers/creatify.ts and ai-avatar-video skill Part 2.4).
VIDEO_PROVIDER=omnihuman
RUNCOMFY_TOKEN=

# Only needed if VIDEO_PROVIDER=aurora — get these from creatify.ai →
# Settings → API.
CREATIFY_API_ID=
CREATIFY_API_KEY=

# Public base URL of this app (used to build absolute media URLs sent to
# external services). In dev this is usually http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
