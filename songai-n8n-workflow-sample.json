            { "name": "Authorization", "value": "Bearer sk-SAMPLE_STABILITY_KEY_REPLACE_ME_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" },
            { "name": "Accept", "value": "audio/mpeg" }
          ]
        },
        "sendBody": true,
        "contentType": "form-data",
        "bodyParameters": {
          "parameters": [
            { "name": "prompt", "value": "={{ $json.musicPrompt }}" },
            { "name": "duration", "value": "120" },
            { "name": "output_format", "value": "mp3" }
          ]
        },
        "options": { "timeout": 60000, "response": { "response": { "responseFormat": "file" } } }
      },
      "id": "generate-music-stability",
      "name": "تولید موسیقی - Stable Audio 2.0",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 640]
    },
