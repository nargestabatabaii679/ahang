          "conditions": [
            {
              "leftValue": "={{ $json.status }}",
              "rightValue": "done",
              "operator": { "type": "string", "operation": "equals" }
            }
          ]
        }
      },
      "id": "if-video-done",
      "name": "ویدیو آماده شد؟",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [660, 1100]
    },
    {
      "parameters": {
        "jsCode": "const jobId = $('اعتبارسنجی و ساخت Job').item.json.id;\nconst lyrics = $('استخراج متن اشعار').item.json.lyrics;\n\nconst result = {\n  lyrics,\n  audioUrl: `/public/media/${jobId}-audio.mp3`,\n  musicUrl: `/public/media/${jobId}-music.mp3`,\n  coverArtUrl: `/public/media/${jobId}-cover.jpg`,\n  videoUrl: $('بررسی وضعیت ویدیو').item.json.output_video || null\n};\n\nconst stages = [\n  { id: 'lyrics',   status: 'done' },\n  { id: 'music',    status: 'done' },\n  { id: 'voice',    status: 'done' },\n  { id: 'video',    status: result.videoUrl ? 'done' : 'error' },\n  { id: 'finalize', status: 'done' }\n];\n\nreturn [{ json: { id: jobId, status: 'done', stages, progress: 100, result } }];"
      },
      "id": "finalize-job",
      "name": "نهایی‌سازی Job",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 1100]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE jobs SET status='done', stages='{{ JSON.stringify($json.stages) }}', progress=100, result='{{ JSON.stringify($json.result) }}' WHERE id='{{ $json.id }}'",
        "options": {}
      },
      "id": "db-update-done",
      "name": "بروزرسانی Job در DB (Done)",
      "type": "n8n-nodes-base.sqlite",
      "typeVersion": 1,
      "position": [1100, 1100],
      "credentials": {
        "sqlite": { "id": "sqlite-cred", "name": "SQLite - jobs.db" }
      }
    },
    {
      "parameters": {
