        "jsonBody": "={\n  \"text\": \"{{ $('استخراج متن اشعار').item.json.lyrics }}\",\n  \"model_id\": \"eleven_multilingual_v2\",\n  \"voice_settings\": { \"stability\": 0.3, \"similarity_boost\": 0.9, \"style\": 0.4, \"use_speaker_boost\": true }\n}",
        "options": { "timeout": 120000, "response": { "response": { "responseFormat": "file" } } }
      },
