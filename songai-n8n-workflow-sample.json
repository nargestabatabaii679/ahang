        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer aa-SAMPLE_KEY_REPLACE_ME_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"messages\": [{ \"role\": \"user\", \"content\": \"{{ $('آماده‌سازی Prompt اشعار').item.json.lyricsPrompt }}\" }]\n}",
        "options": { "timeout": 30000 }
      },
      "id": "generate-lyrics-avalai",
      "name": "تولید اشعار - AvvalAI (Fallback)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 560]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "leftValue": "={{ $json.content }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty" }
            }
          ]
        }
      },
      "id": "if-lyrics-ok",
      "name": "اشعار تولید شد؟",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [660, 500]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nlet lyrics = '';\n\nif (response.content && Array.isArray(response.content)) {\n  lyrics = response.content[0]?.text || '';\n} else if (response.choices) {\n  lyrics = response.choices[0]?.message?.content || '';\n}\n\nif (!lyrics) {\n  const name = $('آماده‌سازی Prompt اشعار').item.json.brief.recipientName;\n  lyrics = `${name} عزیز\\nاین ترانه برای توست\\nبا تمام محبت‌هایم\\nتقدیم به تو می‌کنم\\n\\nهر لحظه با یادت هستم\\nهر قدم با دلم می‌آیم\\nای دوست مهربانم\\nهمیشه در کنارت می‌مانم`;\n}\n\nreturn [{ json: { lyrics, stage: 'lyrics', progress: 20 } }];"
      },
      "id": "extract-lyrics",
      "name": "استخراج متن اشعار",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 500]
    },
    {
      "parameters": {
        "jsCode": "const brief = $('اعتبارسنجی و ساخت Job').item.json.brief;\n\nconst genreMusicMap = {\n  romantic: 'romantic Persian pop, soft strings, emotional piano, middle eastern flute',\n  emotional: 'melancholic Persian ballad, violin, minor key, slow tempo',\n  happy: 'upbeat Persian pop, bright synths, energetic drums, 120 BPM',\n  calm: 'ambient Persian music, soft oud, gentle rhythm, peaceful',\n  motivational: 'epic orchestral Persian, powerful drums, rising strings, inspiring',\n  nostalgic: 'classic Iranian pop style, acoustic guitar, warm melody, 70s influence'\n};\n\nconst musicPrompt = genreMusicMap[brief.genre] || 'Persian pop music, emotional, melodic';\nconst coverArtPrompt = `Album cover art for Persian song gift, ${brief.genre} style, beautiful calligraphy with name \"${brief.recipientName}\", warm colors, artistic`;\n\nreturn [{ json: { musicPrompt, coverArtPrompt, genre: brief.genre } }];"
      },
      "id": "prepare-music-prompt",
      "name": "آماده‌سازی Prompt موسیقی",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 700]
    },
    {
