{
  "name": "SongAI - نمونه با داده‌های تستی",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "jobs",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-create-job",
      "name": "POST /api/jobs",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300],
      "webhookId": "songai-create-job"
    },
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "jobs/:id",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-poll-job",
      "name": "GET /api/jobs/:id",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 500],
      "webhookId": "songai-poll-job"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst required = ['recipientName', 'relationship', 'occasion', 'genre', 'photoUrl', 'voiceUrl', 'consent'];\nfor (const field of required) {\n  if (!body[field]) throw new Error(`فیلد ${field} الزامی است`);\n}\n\nif (!body.consent) throw new Error('رضایت الزامی است');\n\nconst validRelationships = ['partner', 'family', 'friend', 'coworker', 'special', 'other'];\nif (!validRelationships.includes(body.relationship)) throw new Error('نوع رابطه نامعتبر است');\n\nconst validGenres = ['romantic', 'emotional', 'happy', 'calm', 'motivational', 'nostalgic'];\nif (!validGenres.includes(body.genre)) throw new Error('ژانر نامعتبر است');\n\nconst jobId = Math.random().toString(16).slice(2, 14);\n\nconst job = {\n  id: jobId,\n  status: 'running',\n  brief: {\n    recipientName: body.recipientName.slice(0, 60),\n    relationship: body.relationship,\n    relationshipOther: body.relationshipOther?.slice(0, 40),\n    occasion: body.occasion,\n    genre: body.genre,\n    aboutText: body.aboutText?.slice(0, 600) || '',\n    photoUrl: body.photoUrl,\n    voiceUrl: body.voiceUrl,\n    consent: true\n  },\n  stages: [\n    { id: 'lyrics',   status: 'pending' },\n    { id: 'music',    status: 'pending' },\n    { id: 'voice',    status: 'pending' },\n    { id: 'video',    status: 'pending' },\n    { id: 'finalize', status: 'pending' }\n  ],\n  progress: 0,\n  result: {},\n  createdAt: Date.now()\n};\n\nreturn [{ json: job }];"
      },
      "id": "validate-and-create-job",
      "name": "اعتبارسنجی و ساخت Job",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO jobs (id, status, brief, stages, progress, result, created_at) VALUES ('{{ $json.id }}', '{{ $json.status }}', '{{ JSON.stringify($json.brief) }}', '{{ JSON.stringify($json.stages) }}', 0, '{}', {{ $json.createdAt }})",
        "options": {}
      },
      "id": "db-insert-job",
      "name": "ذخیره Job در SQLite",
      "type": "n8n-nodes-base.sqlite",
      "typeVersion": 1,
      "position": [440, 300],
      "credentials": {
        "sqlite": {
          "id": "sqlite-cred",
          "name": "SQLite - jobs.db"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { id: $('اعتبارسنجی و ساخت Job').item.json.id, pollUrl: `/api/jobs/${$('اعتبارسنجی و ساخت Job').item.json.id}` } }}"
      },
      "id": "respond-job-created",
      "name": "پاسخ: Job ایجاد شد",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [660, 300]
    },
    {
      "parameters": {
        "jsCode": "const brief = $input.first().json.brief;\n\nconst genreMap = { romantic: 'عاشقانه و احساسی', emotional: 'غم‌انگیز و عمیق', happy: 'شاد و پرانرژی', calm: 'آرام و ملایم', motivational: 'انگیزشی و قوی', nostalgic: 'نوستالژیک و خاطره‌انگیز' };\nconst occasionMap = { birthday: 'تولد', anniversary: 'سالگرد', appreciation: 'قدردانی', apology: 'عذرخواهی', celebration: 'جشن', none: 'هدیه‌ای ویژه' };\nconst relationshipMap = { partner: 'همسر/شریک زندگی', family: 'عضو خانواده', friend: 'دوست', coworker: 'همکار', special: 'فرد خاص', other: brief.relationshipOther || 'دیگری' };\n\nconst prompt = `یک ترانه فارسی زیبا و احساسی بنویس با این مشخصات:\\n\\nگیرنده: ${brief.recipientName}\\nرابطه: ${relationshipMap[brief.relationship]}\\nمناسبت: ${occasionMap[brief.occasion]}\\nسبک موسیقی: ${genreMap[brief.genre]}\\n${brief.aboutText ? `اطلاعات بیشتر: ${brief.aboutText}` : ''}\\n\\nقوانین:\\n- ۳ تا ۴ بند داشته باشد، هر بند ۴ سطر\\n- سطرها قافیه داشته باشند\\n- نام ${brief.recipientName} در ترانه ذکر شود\\n- کاملاً فارسی باشد\\n- فقط متن ترانه را بنویس`;\n\nreturn [{ json: { ...($input.first().json), lyricsPrompt: prompt } }];"
      },
      "id": "prepare-lyrics-prompt",
      "name": "آماده‌سازی Prompt اشعار",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [220, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "sk-ant-api03-SAMPLE_KEY_REPLACE_ME-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-XXXXXXXX" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": { "parameters": [] },
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 1024,\n  \"messages\": [{ \"role\": \"user\", \"content\": \"{{ $json.lyricsPrompt }}\" }]\n}",
        "options": { "timeout": 30000 }
      },
      "id": "generate-lyrics-anthropic",
      "name": "تولید اشعار - Anthropic Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 420]
    },
    {
      "parameters": {
        "method": "POST",
