      }
    },
    {
      "parameters": {
        "jsCode": "const row = $input.first().json;\nif (!row || !row.id) {\n  $response.statusCode = 404;\n  return [{ json: { error: 'Job یافت نشد' } }];\n}\n\nreturn [{ json: { id: row.id, status: row.status, progress: row.progress, stages: JSON.parse(row.stages || '[]'), result: JSON.parse(row.result || '{}'), error: row.error || null, createdAt: row.created_at } }];"
      },
