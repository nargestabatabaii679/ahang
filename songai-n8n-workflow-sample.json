            { "name": "model", "value": "sd3.5-large" },
            { "name": "aspect_ratio", "value": "1:1" },
            { "name": "output_format", "value": "jpeg" }
          ]
        },
        "options": { "timeout": 60000, "response": { "response": { "responseFormat": "file" } } }
      },
      "id": "generate-cover-art",
      "name": "تولید کاور آرت - Stable Diffusion 3.5",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [440, 780]
    },
    {
