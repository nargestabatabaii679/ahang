            { "name": "files", "value": "={{ $('اعتبارسنجی و ساخت Job').item.json.brief.voiceUrl }}" },
            { "name": "description", "value": "Instant voice clone for song gift" }
          ]
        },
        "options": { "timeout": 60000 }
      },
      "id": "clone-voice-elevenlabs",
      "name": "کلون صدا - ElevenLabs",
