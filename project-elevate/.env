# ── Pipeline providers ────────────────────────────────────────────
MUSIC_PROVIDER=suno
VIDEO_PROVIDER=stability
# PIPELINE_MOCK=true

# ── Lyrics: Anthropic Claude (بهترین برای شعر فارسی) ─────────────
ANTHROPIC_API_KEY=

# ── Lyrics fallback: AvvalAI (OpenAI-compatible, Iran) ────────────
AVALAI_API_KEY=
AVALAI_API_BASE=https://api.avalai.ir/v1

# ── Lyrics fallback: OpenRouter ───────────────────────────────────
OPENROUTER_API_KEY=

# ── Voice: ElevenLabs (کلون صدا + TTS) ──────────────────────────
ELEVENLABS_API_KEY=

# ── Music: Suno (self-hosted gcui-art/suno-api) ───────────────────
# راه‌اندازی: git clone https://github.com/gcui-art/suno-api && docker-compose up
SUNO_API_BASE=http://localhost:3000

# ── Image & Video: Stability AI ──────────────────────────────────
STABILITY_API_KEY=

# ── Video: HeyGen Avatar V ────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ── Video: Creatify Aurora (lipsync از عکس) ──────────────────────
CREATIFY_API_ID=
CREATIFY_API_KEY=
