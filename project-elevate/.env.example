# ── LLM (متن آهنگ) — حداقل یکی لازم است ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude (بهترین برای فارسی)
AVALAI_API_KEY=...                    # AvvalAI (ایران-based fallback)
AVALAI_API_BASE=https://api.avalai.ir/v1
OPENROUTER_API_KEY=...               # OpenRouter fallback

# ── صدا (Voice Clone + TTS) ──────────────────────────────────────
ELEVENLABS_API_KEY=...               # REQUIRED برای کلون صدا

# ── موسیقی پس‌زمینه — یکی را انتخاب کنید ────────────────────────
MUSIC_PROVIDER=stability             # stability | suno | riffusion | elevenlabs | auto
STABILITY_API_KEY=...                # Stable Audio 2.0
SUNO_API_BASE=http://localhost:8000  # self-hosted Suno
RIFFUSION_API_BASE=http://localhost:8080

# ── ویدیو (Lipsync) — اختیاری ────────────────────────────────────
VIDEO_PROVIDER=aurora                # aurora | heygen | stability
CREATIFY_API_ID=...                  # Creatify Aurora
CREATIFY_API_KEY=...
HEYGEN_API_KEY=...                   # HeyGen
HEYGEN_AVATAR_ID=...
HEYGEN_VOICE_ID=...

# ── مسیرهای ذخیره‌سازی (لیارا disk mount) ────────────────────────
DATA_DIR=/app/data                   # SQLite database
MEDIA_DIR=/app/public/media          # فایل‌های صوتی و تصویری
