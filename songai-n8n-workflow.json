    {
      "parameters": {
        "jsCode": "// ساخت prompt موسیقی و کاور آرت\nconst brief = $('اعتبارسنجی و ساخت Job').item.json.brief;\n\nconst genreMusicMap = {\n  romantic: 'romantic Persian pop, soft strings, emotional piano, middle eastern flute',\n  emotional: 'melancholic Persian ballad, violin, minor key, slow tempo',\n  happy: 'upbeat Persian pop, bright synths, energetic drums, 120 BPM',\n  calm: 'ambient Persian music, soft oud, gentle rhythm, peaceful',\n  motivational: 'epic orchestral Persian, powerful drums, rising strings, inspiring',\n  nostalgic: 'classic Iranian pop style, acoustic guitar, warm melody, 70s influence'\n};\n\nconst musicPrompt = genreMusicMap[brief.genre] || 'Persian pop music, emotional, melodic';\nconst coverArtPrompt = `Album cover art for Persian song gift, ${brief.genre} style, beautiful calligraphy with name \"${brief.recipientName}\", warm colors, artistic`;\n\nreturn [{ json: { musicPrompt, coverArtPrompt, genre: brief.genre } }];"
      },
