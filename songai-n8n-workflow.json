    {
      "parameters": {
        "jsCode": "// جمع‌آوری نتایج همه مراحل\nconst jobId = $('اعتبارسنجی و ساخت Job').item.json.id;\nconst lyrics = $('استخراج متن اشعار').item.json.lyrics;\n\nconst result = {\n  lyrics,\n  audioUrl: `/public/media/${jobId}-audio.mp3`,\n  musicUrl: `/public/media/${jobId}-music.mp3`,\n  coverArtUrl: `/public/media/${jobId}-cover.jpg`,\n  videoUrl: $('check-video-status').item.json.output_video || null\n};\n\nconst stages = [\n  { id: 'lyrics',   status: 'done' },\n  { id: 'music',    status: 'done' },\n  { id: 'voice',    status: 'done' },\n  { id: 'video',    status: result.videoUrl ? 'done' : 'error' },\n  { id: 'finalize', status: 'done' }\n];\n\nreturn [{\n  json: {\n    id: jobId,\n    status: 'done',\n    stages,\n    progress: 100,\n    result\n  }\n}];"
      },
