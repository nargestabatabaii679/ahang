
{
  "name": "SongAI - تولید هدیه موسیقی شخصی‌سازی‌شده",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "jobs",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-create-job",
      "name": "POST /api/jobs",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        300
      ],
      "webhookId": "songai-create-job",
      "notes": "دریافت اطلاعات کاربر: recipientName, relationship, occasion, genre, aboutText, photoUrl, voiceUrl, consent"
    },
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "jobs/:id",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-poll-job",
      "name": "GET /api/jobs/:id",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        500
      ],
      "webhookId": "songai-poll-job"
    },
    {
      "parameters": {
        "jsCode": "// اعتبارسنجی ورودی‌ها\nconst body = $input.first().json.body;\n\nconst required = ['recipientName', 'relationship', 'occasion', 'genre', 'photoUrl', 'voiceUrl', 'consent'];\nfor (const field of required) {\n  if (!body[field]) throw new Error(`فیلد ${field} الزامی است`);\n}\n\nif (!body.consent) throw new Error('رضایت الزامی است');\n\nconst validRelationships = ['partner', 'family', 'friend', 'coworker', 'special', 'other'];\nif (!validRelationships.includes(body.relationship)) {\n  throw new Error('نوع رابطه نامعتبر است');\n}\n\nconst validGenres = ['romantic', 'emotional', 'happy', 'calm', 'motivational', 'nostalgic'];\nif (!validGenres.includes(body.genre)) {\n  throw new Error('ژانر نامعتبر است');\n}\n\n// ساخت Job ID\nconst jobId = Math.random().toString(16).slice(2, 14);\n\nconst job = {\n  id: jobId,\n  status: 'running',\n  brief: {\n    recipientName: body.recipientName.slice(0, 60),\n    relationship: body.relationship,\n    relationshipOther: body.relationshipOther?.slice(0, 40),\n    occasion: body.occasion,\n    genre: body.genre,\n    aboutText: body.aboutText?.slice(0, 600) || '',\n    photoUrl: body.photoUrl,\n    voiceUrl: body.voiceUrl,\n    consent: true\n  },\n  stages: [\n    { id: 'lyrics',   status: 'pending' },\n    { id: 'music',    status: 'pending' },\n    { id: 'voice',    status: 'pending' },\n    { id: 'video',    status: 'pending' },\n    { id: 'finalize', status: 'pending' }\n  ],\n  progress: 0,\n  result: {},\n  createdAt: Date.now()\n};\n\nreturn [{ json: job }];"
      },
      "id": "validate-and-create-job",
      "name": "اعتبارسنجی و ساخت Job",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO jobs (id, status, brief, stages, progress, result, created_at) VALUES ('{{ $json.id }}', '{{ $json.status }}', '{{ JSON.stringify($json.brief) }}', '{{ JSON.stringify($json.stages) }}', 0, '{}', {{ $json.createdAt }})",
        "options": {}
      },
      "id": "db-insert-job",
      "name": "ذخیره Job در SQLite",
      "type": "n8n-nodes-base.sqlite",
      "typeVersion": 1,
      "position": [
        440,
        300
      ],
      "credentials": {
        "sqlite": {
          "id": "sqlite-cred",
          "name": "SQLite - jobs.db"
        }
      }
