    {
      "parameters": {
        "jsCode": "// استخراج اشعار از پاسخ Anthropic یا AvvalAI\nconst response = $input.first().json;\nlet lyrics = '';\n\nif (response.content && Array.isArray(response.content)) {\n  // Anthropic format\n  lyrics = response.content[0]?.text || '';\n} else if (response.choices) {\n  // OpenAI-compatible format (AvvalAI)\n  lyrics = response.choices[0]?.message?.content || '';\n}\n\nif (!lyrics) {\n  // Fallback template\n  const name = $('آماده‌سازی Prompt اشعار').item.json.brief.recipientName;\n  lyrics = `${name} عزیز\\nاین ترانه برای توست\\nبا تمام محبت‌هایم\\nتقدیم به تو می‌کنم\\n\\nهر لحظه با یادت هستم\\nهر قدم با دلم می‌آیم\\nای دوست مهربانم\\nهمیشه در کنارت می‌مانم`;\n}\n\nreturn [{ json: { lyrics, stage: 'lyrics', progress: 20 } }];"
      },
      "id": "extract-lyrics",
      "name": "استخراج متن اشعار",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        500
      ]
